{
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Blindful Extension",
    "default_popup": "popup/index.html"
  },
  "commands": {
    "textToSpeech": {
      "suggested_key": {
        "windows": "Ctrl+Shift+P",
        "mac": "Ctrl+Shift+P",
        "chromeos": "Ctrl+Shift+P",
        "linux": "Ctrl+Shift+P"
      },
      "description": "Text to Speech",
      "global": true
    },
    "speechToText": {
      "suggested_key": {
        "windows": "Ctrl+Shift+Y",
        "mac": "Ctrl+Shift+Y",
        "chromeos": "Ctrl+Shift+Y",
        "linux": "Ctrl+Shift+Y"
      },
      "global": true,
      "description": "Speech to Text"
    }
  },
  "description": "Blindful - Accessibility extension for visually impaired users",
  "manifest_version": 3,
  "name": "Blindful Extension",
  "version": "0.3",
  "permissions": [
    "webNavigation",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "numbers.js",
        "parser.js",
        "textToSpeech.js",
        "speechToText.js",
        "bouncing.js"
      ],
      "run_at": "document_idle"
    }
  ]
}